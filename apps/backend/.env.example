# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=

# Database
DATABASE_URL=postgresql://agent:password@localhost:5432/completepay_agent
REDIS_URL=redis://localhost:6379

# Vector Store (PgVector usa mesmo DATABASE_URL)

# MCP (opcional - servidor Model Context Protocol externo)
# MCP_SERVER_URL=http://localhost:8080/mcp

# Application
APP_ENV=development
LOG_LEVEL=INFO
# LOG_FORMAT=json   # descomente para logs estruturados (uma linha JSON por evento)
HIGH_VALUE_THRESHOLD=10000

# Agno
AGNO_TELEMETRY=false

# Security
JWT_SECRET=...
API_RATE_LIMIT=100

# CORS: origens permitidas (separadas por virgula). Em producao use o dominio do frontend (ex: https://complete-pay-saa-s-frontend-xxx.vercel.app).
CORS_ORIGINS=http://localhost:3000,http://localhost:3003
# Producao: adicione a URL do frontend na Vercel (Settings > Environment Variables).
#
# Avatar em producao (Vercel): crie um Blob store no projeto e defina o token abaixo.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# URL do frontend (links de confirmacao de email). Em producao use o dominio do app.
FRONTEND_URL=http://localhost:3003

# Email (Resend) - confirmacao de conta e modulo calendario
# RESEND_API_KEY=re_...
# EMAIL_FROM_ADDRESS=no-reply@seudominio.com
# EMAIL_FROM_NAME=CompletePay